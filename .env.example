# =============================================================================
# ANDRADE, Estúdio digital — variáveis de ambiente
# Copie para .env.local e preencha. Toda integração opcional degrada com
# elegância: env ausente desliga o recurso sem erro.
# =============================================================================

# URL pública do site. Em dev: http://localhost:3000
# Em produção: https://seu-projeto.vercel.app ou o domínio próprio.
NEXT_PUBLIC_SITE_URL=

# --- Supabase (obrigatório para leads, eventos e admin) -----------------------
# Painel do Supabase > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: SOMENTE no servidor. Jamais exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (e-mails automáticos: estimativa, follow-up, digest) --------------
# https://resend.com > API Keys. Free: 3.000 e-mails/mês, 100/dia.
RESEND_API_KEY=

# E-mail interno do estúdio: recebe notificação de lead e o digest semanal.
ADMIN_EMAIL=matheus.andrade.c.santos@gmail.com

# --- Telegram (opcional: notificação instantânea de lead no celular) ----------
# Crie o bot com o @BotFather e obtenha o chat id. Sem estes envs, o recurso
# fica desligado sem erro.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Cloudflare Turnstile (opcional em dev: anti-spam invisível) --------------
# Sem estes envs, a checagem é pulada com aviso no log do servidor.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Crons da Vercel -----------------------------------------------------------
# Segredo que protege /api/cron/diario e /api/cron/semanal.
# Gere um valor aleatório longo (ex.: openssl rand -hex 32).
CRON_SECRET=
